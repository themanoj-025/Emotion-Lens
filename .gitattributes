# Auto-detect text files and normalize line endings
* text=auto

# Python source
*.py text diff=python

# Jupyter notebooks
*.ipynb text diff=jupyter

# Markdown documentation
*.md text
*.rst text

# Config files
*.yml text
*.yaml text
*.toml text
*.json text
*.cfg text
*.compose text
*.env text

# Shell / batch scripts
*.sh text eol=lf
*.bat text eol=crlf

# Docker
Dockerfile text
Dockerfile.* text

# Requirements
requirements.txt text
runtime.txt text
packages.txt text

# SVG assets (stored in repo)
*.svg text

# Binary files - don't modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.h5 binary
*.hdf5 binary
*.pkl binary
*.pickle binary
*.zip binary
